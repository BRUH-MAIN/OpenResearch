FROM node:20-alpine

WORKDIR /app

# Keep curl available for inherited healthcheck from compose.
RUN apk add --no-cache curl

# Install dependencies at build time (including devDependencies).
COPY package.json package-lock.json* ./
RUN npm ci --no-audit

# Copy source so the image is runnable even before bind mounts attach.
COPY . .

ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1
ENV HOSTNAME=0.0.0.0
ENV PORT=3000

EXPOSE 3000

CMD ["npm", "run", "dev", "--", "-H", "0.0.0.0", "-p", "3000"]
