# OpenResearch Docker Environment Configuration
# Copy this file to .env.docker and fill in the required values:
#   cp .env.docker.example .env.docker

# JWT Secrets (MUST be at least 32 characters and different from each other)
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-a-different-random-secret-at-least-32-chars

# Groq API Key (REQUIRED for AI features)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Note: Embeddings use local SPECTER2 model (768-dim) — no external API key needed

# These are typically set in docker-compose.yml, but can be overridden here:
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/openresearch
# CLIENT_URL=http://localhost:3000
# AI_SERVICE_URL=http://ai-service:8000
