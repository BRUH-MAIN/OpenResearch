# OpenResearch AI Service Configuration

# Groq API Key (required for AI features - chat/completion)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Groq model to use
GROQ_MODEL=llama-3.3-70b-versatile

# Note: Embeddings use the local SPECTER2 model (768-dim)
# No OpenAI API key is required for embeddings

# Database URL (same as main server, for reading context)
DATABASE_URL=postgresql://openresearch:openresearch@localhost:5433/openresearch

# Main server URL (for potential callbacks)
SERVER_URL=http://localhost:3001

# Debug mode
DEBUG=false
