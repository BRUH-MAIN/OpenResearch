# OpenResearch Docker Environment Configuration

# PostgreSQL Database
POSTGRES_USER=openresearch
POSTGRES_PASSWORD=openresearch
POSTGRES_DB=openresearch

# JWT Secrets (generate with: openssl rand -base64 32)
JWT_SECRET=openresearch-jwt-secret-key-for-docker-minimum-32-chars-abc123
JWT_REFRESH_SECRET=openresearch-refresh-token-secret-for-docker-different-key-xyz789

# Groq API Key (for AI features)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=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
GROQ_MODEL=llama-3.3-70b-versatile

# Client URLs (for production, change to your domain)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Backend Server Configuration
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# AI Service Configuration
AI_SERVICE_PORT=8000
DEBUG=false
MAX_CONTEXT_MESSAGES=50
MAX_CONTEXT_TOKENS=8000
REQUEST_TIMEOUT=30

# Deep Research (Open Deep Research-style)
SUMMARIZATION_MODEL=gpt-oss-120b
RESEARCH_MODEL=gpt-oss-120b
COMPRESSION_MODEL=gpt-oss-120b
FINAL_REPORT_MODEL=gpt-oss-120b

# Tavily Search API (for deep research)
TAVILY_API_KEY=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
SEARCH_API=tavily
TAVILY_SEARCH_DEPTH=advanced
TAVILY_INCLUDE_ANSWER=false
