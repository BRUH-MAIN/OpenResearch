# OpenResearch Docker Environment Configuration
# Copy this file to .env.docker and modify as needed

# JWT Secrets (MUST be at least 32 characters and different from each other)
# Generate with: openssl rand -base64 32
JWT_SECRET=openresearch-jwt-secret-key-for-docker-minimum-32-chars-abc123
JWT_REFRESH_SECRET=openresearch-refresh-token-secret-for-docker-different-key-xyz789

# DeepSeek API Key (primary LLM provider)
DEEPSEEK_API_KEY=sk-c6fa431dd0f94f87b53fd3f0a7112dd9
DEEPSEEK_MODEL=deepseek-chat

# Groq API Key (fallback LLM provider)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=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
GROQ_MODEL=llama-3.1-8b-instant

# Optional: OpenAI API Key (for embeddings)
# If not set, will use the same key as Groq
# OPENAI_API_KEY=your-openai-api-key-here

# These are typically set in docker-compose.yml, but can be overridden here
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/openresearch
# CLIENT_URL=http://localhost:3000
# AI_SERVICE_URL=http://ai-service:8000
