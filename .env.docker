# OpenResearch Docker Environment Configuration
# Copy this file to .env.docker and modify as needed

# JWT Secrets (MUST be at least 32 characters and different from each other)
# Generate with: openssl rand -base64 32
JWT_SECRET=openresearch-jwt-secret-key-for-docker-minimum-32-chars-abc123
JWT_REFRESH_SECRET=openresearch-refresh-token-secret-for-docker-different-key-xyz789

# Google AI Studio API Key (required for AI features)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyDqnZ_QxVehpdh5KVI96JAOYvtmwo4eBg8
GEMINI_MODEL=gemini-3-flash-preview

