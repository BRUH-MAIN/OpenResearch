# =============================================================================
# OpenResearch — environment configuration
# =============================================================================
# Local (non-Docker) development:
#   cp .env.example .env
# Docker:
#   cp .env.example .env.docker    (docker compose reads .env.docker)
#
# Never commit a filled-in copy: .env* is gitignored except these templates.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Postgres 16 + pgvector)
# -----------------------------------------------------------------------------
# docker compose builds DATABASE_URL from these three values.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=openresearch

# Used when running services outside Docker:
DATABASE_URL=postgresql://postgres:change-me@localhost:5432/openresearch

# -----------------------------------------------------------------------------
# Auth (REQUIRED — the two secrets must differ, min 32 chars each)
# -----------------------------------------------------------------------------
# Generate each with: openssl rand -hex 32
JWT_SECRET=
JWT_REFRESH_SECRET=

# -----------------------------------------------------------------------------
# LLM — chat, Q&A, summarization (at least one REQUIRED)
# -----------------------------------------------------------------------------
# DeepSeek is the primary provider; Groq is the automatic fallback.
DEEPSEEK_API_KEY=          # https://platform.deepseek.com/api_keys
GROQ_API_KEY=              # https://console.groq.com/keys

# -----------------------------------------------------------------------------
# Embeddings — RAG retrieval (REQUIRED)
# -----------------------------------------------------------------------------
# gemini-embedding-001, truncated to 768 dims (Matryoshka) to match the
# pgvector column and its HNSW index. The free tier is enough for development.
GEMINI_API_KEY=            # https://aistudio.google.com/apikey

# -----------------------------------------------------------------------------
# Service URLs
# -----------------------------------------------------------------------------
CLIENT_URL=http://localhost:3000
AI_SERVICE_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Browser-facing host, for testing from another device on your LAN:
# PUBLIC_HOST=192.168.1.50
