# =============================================================================
# OpenResearch Environment Configuration
# =============================================================================
# This file contains configuration for all three services:
# - Backend Server (Node.js/Express)
# - Frontend Client (Next.js)
# - AI Service (Python/FastAPI)
#
# Instructions:
# 1. Copy this file to create service-specific .env files:
#    - server/.env
#    - client/.env.local
#    - ai-service/.env
# 2. Fill in the required values for each service
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Database Configuration
# -----------------------------------------------------------------------------
# For local PostgreSQL:
DATABASE_URL=postgresql://postgres:your-password@localhost:5432/openresearch

# For Neon serverless (recommended for production):
# DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/openresearch?sslmode=require

# -----------------------------------------------------------------------------
# JWT Authentication Secrets (REQUIRED - MUST BE DIFFERENT)
# -----------------------------------------------------------------------------
# Generate secure secrets with: openssl rand -base64 48
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-change-in-production
JWT_REFRESH_SECRET=your-different-super-secret-refresh-key-minimum-32-characters

# -----------------------------------------------------------------------------
# Groq AI Configuration (REQUIRED for AI features)
# -----------------------------------------------------------------------------
# Get your API key from: https://console.groq.com/keys
# Using Groq SDK for fast inference with Llama models
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Deep Research (Open Deep Research-style)
# Use Groq-hosted OpenAI GPT-OSS-120B for deep research agent only
SUMMARIZATION_MODEL=gpt-oss-120b
RESEARCH_MODEL=gpt-oss-120b
COMPRESSION_MODEL=gpt-oss-120b
FINAL_REPORT_MODEL=gpt-oss-120b

# Tavily Search API (for deep research)
TAVILY_API_KEY=your-tavily-api-key-here
SEARCH_API=tavily  # tavily | mcp | vector_store | hybrid
TAVILY_SEARCH_DEPTH=advanced
TAVILY_INCLUDE_ANSWER=false

# Note: Embeddings use local SPECTER2 model (768-dim) — no OpenAI key needed
# OPENAI_API_KEY is not required

# -----------------------------------------------------------------------------
# Backend Server Configuration (server/.env)
# -----------------------------------------------------------------------------
PORT=3001
NODE_ENV=development  # Options: development, production, test
CLIENT_URL=http://localhost:3000  # Frontend URL for CORS

# -----------------------------------------------------------------------------
# Frontend Client Configuration (client/.env.local)
# -----------------------------------------------------------------------------
# Note: Must use NEXT_PUBLIC_ prefix for client-side variables
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# AI Service Configuration (ai-service/.env)
# -----------------------------------------------------------------------------
AI_SERVICE_PORT=8000
DEBUG=false

# AI Service Limits
MAX_CONTEXT_MESSAGES=50
MAX_CONTEXT_TOKENS=8000
REQUEST_TIMEOUT=30

# -----------------------------------------------------------------------------
# Production Checklist
# -----------------------------------------------------------------------------
# [ ] Set up PostgreSQL database (Neon recommended)
# [ ] Generate strong JWT secrets (32+ characters, different from each other)
# [ ] Obtain Groq API key from Groq Console
# [ ] Set NODE_ENV=production
# [ ] Update URLs to production domains (CLIENT_URL, NEXT_PUBLIC_*)
# [ ] Configure SSL/TLS (use reverse proxy like Nginx/Caddy)
# [ ] Set up database backups
# [ ] Configure monitoring and logging
# [ ] Review rate limits and security settings
# -----------------------------------------------------------------------------
